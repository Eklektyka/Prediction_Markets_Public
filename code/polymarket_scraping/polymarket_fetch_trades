#!/usr/bin/env python3
import os, sys, time, csv, gzip, math, threading, datetime as dt
from collections import deque
from concurrent.futures import ThreadPoolExecutor, as_completed

import requests
from urllib3.util.retry import Retry
from requests.adapters import HTTPAdapter

# =========================
# Config
# =========================
EVENTS_URL = "https://gamma-api.polymarket.com/events"
MARKETS_URL = "https://gamma-api.polymarket.com/markets"
TRADES_URL  = "https://data-api.polymarket.com/trades"

BATCH_SIZE = 20
MARKETS_PAGE_LIMIT = 100
TRADES_PAGE_LIMIT = 500
TAKER_ONLY = False                     # True = taker-only trades
CSV_PATH = "polymarket_fed_trades.csv.gz"
TIMEOUT = 30
MAX_WORKERS = 8                        # parallel markets fetch
FLUSH_EVERY = 1000                     # flush CSV every N rows

# Progress / watchdog
HEARTBEAT_SECONDS = 15
MAX_MINUTES = None                     # e.g. 60 to auto-stop after 1 hour

fed_event_slugs = [
   "fed-interest-rates-march-2022","fed-interest-rates-may-2022","fed-interest-rates-june-2022",
   "fed-interest-rates-july-2022","fed-interest-rates-september-2022","fed-interest-rates-november-2022",
   "fed-interest-rates-december-2022",
   "fed-interest-rates-february-2023","fed-interest-rates-march-2023","fed-interest-rates-may-2023",
   "fed-interest-rates-june-2023","fed-interest-rates-july-2023","fed-interest-rates-september-2023",
   "fed-interest-rates-november-2023","fed-interest-rates-december-2023",
   "fed-interest-rates-january-2024","fed-interest-rates-march-2024","fed-interest-rates-may-2024",
   "fed-interest-rates-june-2024","fed-interest-rates-july-2024","fed-interest-rates-september-2024",
   "fed-interest-rates-november-2024","fed-interest-rates-december-2024",
   "fed-decision-in-march","fed-decision-in-may-2025","fed-decision-in-june",
   "fed-decision-in-july","fed-decision-in-september","fed-decision-in-october",
]

# =========================
# Progress state
# =========================
prog_lock = threading.Lock()
state = {
    "markets_total": 0,
    "markets_done": 0,
    "pages_total": 0,        # pages from /trades
    "trades_written": 0,
    "start_ts": time.time(),
    "stop_flag": False,
}

def log(msg: str):
    now = dt.datetime.now().strftime("%H:%M:%S")
    print(f"[{now}] {msg}", flush=True)

def eta_text(done: int, total: int, start_ts: float):
    if total <= 0 or done <= 0:
        return "ETA: --"
    elapsed = time.time() - start_ts
    rate = done / max(elapsed, 1e-9)
    remaining = (total - done) / max(rate, 1e-9)
    return f"ETA: {int(remaining/60)}m {int(remaining%60)}s (rate {rate:.2f} mkts/s)"

def heartbeat_thread():
    last_written = 0
    while not state["stop_flag"]:
        time.sleep(HEARTBEAT_SECONDS)
        with prog_lock:
            tw = state["trades_written"]
            md = state["markets_done"]
            mt = state["markets_total"]
            pg = state["pages_total"]
            eta = eta_text(md, mt, state["start_ts"])
        delta = tw - last_written
        last_written = tw
        log(f"⏳ Heartbeat: {md}/{mt} markets, {pg} pages, {tw} rows (+{delta} in {HEARTBEAT_SECONDS}s). {eta}")
        if MAX_MINUTES and (time.time() - state["start_ts"]) > MAX_MINUTES * 60:
            log("⛔ MAX_MINUTES reached; stopping politely…")
            with prog_lock:
                state["stop_flag"] = True
            break

# =========================
# HTTP session
# =========================
def make_session():
    s = requests.Session()
    retries = Retry(
        total=6,
        backoff_factor=0.4,
        status_forcelist=[429, 500, 502, 503, 504],
        allowed_methods=["GET"],
        raise_on_status=False,
    )
    adapter = HTTPAdapter(pool_connections=64, pool_maxsize=64, max_retries=retries)
    s.mount("http://", adapter)
    s.mount("https://", adapter)
    s.headers.update({"User-Agent": "polymarket-scraper/1.0"})
    return s

SESSION = make_session()

# =========================
# Helpers
# =========================
def fetch_by_slugs(slugs, batch=BATCH_SIZE):
    out = []
    for i in range(0, len(slugs), batch):
        chunk = slugs[i:i+batch]
        params = [("slug", s) for s in chunk] + [("limit", 100)]
        r = SESSION.get(EVENTS_URL, params=params, timeout=TIMEOUT)
        r.raise_for_status()
        out.extend(r.json())
    # dedupe
    seen, deduped = set(), []
    for e in out:
        k = e.get("id") or e.get("slug")
        if k not in seen:
            seen.add(k)
            deduped.append(e)
    return deduped

def fetch_markets_for_event(event, limit=MARKETS_PAGE_LIMIT):
    if isinstance(event.get("markets"), list) and event["markets"]:
        return event["markets"]

    fallbacks = [
        {"event_id": event.get("id")},
        {"eventId": event.get("id")},
        {"event_slug": event.get("slug")},
        {"eventSlug": event.get("slug")},
    ]
    for base_params in fallbacks:
        if not list(base_params.values())[0]:
            continue
        gathered, offset = [], 0
        while True:
            params = {**base_params, "limit": limit, "offset": offset}
            r = SESSION.get(MARKETS_URL, params=params, timeout=TIMEOUT)
            if r.status_code == 422:
                break
            if not r.ok:
                break
            page = r.json()
            if isinstance(page, dict) and "markets" in page:
                page = page["markets"]
            if not page:
                break
            gathered.extend(page)
            if len(page) < limit:
                break
            offset += limit
        if gathered:
            return gathered
    return []


def fetch_trades_for_market(condition_id, limit=TRADES_PAGE_LIMIT, sleep=0.001):
    pages, offset = [], 0
    while True:
        if state["stop_flag"]:
            break
        params = {"market": condition_id, "limit": limit, "offset": offset, "takerOnly": TAKER_ONLY}
        r = SESSION.get(TRADES_URL, params=params, timeout=TIMEOUT)

        if r.status_code == 429:
            log(f"⏳ rate limit hit for {condition_id} @offset {offset}; sleeping 1s")
            time.sleep(1)
            continue  # retry same offset

        if not r.ok:
            log(f"⚠️ trades HTTP {r.status_code} for {condition_id} @offset {offset}; stopping this market")
            break

        page = r.json()
        got = len(page or [])
        with prog_lock:
            state["pages_total"] += 1
        log(f"… {condition_id}: got {got} trades at offset {offset}")
        if not page:
            break
        pages.append(page)
        if got < limit:
            break
        offset += limit
        if sleep:
            time.sleep(sleep)
    return [t for p in pages for t in p]


# =========================
# Writer (streaming)
# =========================
fieldnames = [
    "event_slug","market_id","market_slug","conditionId",
    "timestamp","side","size","price","outcome","outcomeIndex",
    "proxyWallet","name","pseudonym","transactionHash","asset",
]

def open_writer(path):
    if path.endswith(".gz"):
        f = gzip.open(path, "wt", newline="", encoding="utf-8")
    else:
        f = open(path, "w", newline="", encoding="utf-8")
    w = csv.DictWriter(f, fieldnames=fieldnames)
    w.writeheader()
    return f, w

# small rolling dedupe per market (prevents accidental dup rows without big memory)
class RollingDeduper:
    def __init__(self, capacity=5000):
        self.capacity = capacity
        self.q = deque()
        self.s = set()
    def add(self, key):
        if key in self.s:
            return False
        self.q.append(key)
        self.s.add(key)
        if len(self.q) > self.capacity:
            old = self.q.popleft()
            self.s.discard(old)
        return True

# =========================
# Main pipeline
# =========================
def main():
    log("🔎 Fetching events…")
    events = fetch_by_slugs(fed_event_slugs)
    log(f"Events fetched: {len(events)}")

    # Markets
    log("📦 Fetching markets per event…")
    event_to_markets, all_markets_seen = {}, set()
    for ev in events:
        ev_slug = ev.get("slug") or f"id-{ev.get('id')}"
        markets = fetch_markets_for_event(ev)
        cleaned = []
        for m in markets:
            mid = m.get("id")
            cid = m.get("conditionId") or m.get("condition_id")
            if not cid:
                continue
            key = (mid, cid)
            if key in all_markets_seen:
                continue
            all_markets_seen.add(key)
            cleaned.append({
                "id": mid,
                "slug": m.get("slug"),
                "question": m.get("question"),
                "conditionId": cid,
                "endDate": m.get("endDate") or m.get("end_date"),
            })
        event_to_markets[ev_slug] = cleaned

    log("Markets per event (first 5 shown):")
    shown = 0
    for evs, ms in event_to_markets.items():
        log(f"  {evs} → {len(ms)} markets")
        shown += 1
        if shown >= 5:
            break

    # Prepare writer
    f, writer = open_writer(CSV_PATH)
    written = 0

    # Build work list
    work = []
    for ev_slug, markets in event_to_markets.items():
        for m in markets:
            work.append((ev_slug, m))
    with prog_lock:
        state["markets_total"] = len(work)

    log(f"🧵 Starting workers (MAX_WORKERS={MAX_WORKERS}) on {len(work)} markets…")

    # Heartbeat thread
    hb = threading.Thread(target=heartbeat_thread, daemon=True)
    hb.start()

    def task(ev_slug, m):
        cid = m["conditionId"]
        trades = fetch_trades_for_market(cid)
        return ev_slug, m, trades

    try:
        with ThreadPoolExecutor(max_workers=MAX_WORKERS) as ex:
            futures = [ex.submit(task, ev_slug, m) for ev_slug, m in work]
            for fut in as_completed(futures):
                if state["stop_flag"]:
                    break
                ev_slug, m, trades = fut.result()
                dd = RollingDeduper()
                wlocal = 0
                for t in trades:
                    key = (t.get("transactionHash"), t.get("asset"), t.get("timestamp"), t.get("side"))
                    if not dd.add(key):
                        continue
                    writer.writerow({
                        "event_slug": ev_slug,
                        "market_id": m["id"],
                        "market_slug": m["slug"],
                        "conditionId": m["conditionId"],
                        "timestamp": t.get("timestamp"),
                        "side": t.get("side"),
                        "size": t.get("size"),
                        "price": t.get("price"),
                        "outcome": t.get("outcome"),
                        "outcomeIndex": t.get("outcomeIndex"),
                        "proxyWallet": t.get("proxyWallet"),
                        "name": t.get("name"),
                        "pseudonym": t.get("pseudonym"),
                        "transactionHash": t.get("transactionHash"),
                        "asset": t.get("asset"),
                    })
                    written += 1
                    wlocal += 1
                    if written % FLUSH_EVERY == 0:
                        f.flush()
                with prog_lock:
                    state["trades_written"] = written
                    state["markets_done"] += 1
                log(f"✅ finished market {m['conditionId']} → wrote {wlocal} rows "
                    f"({state['markets_done']}/{state['markets_total']})")
        f.flush()
    finally:
        with prog_lock:
            state["stop_flag"] = True
        hb.join(timeout=1)
        f.close()
        log(f"🏁 done. rows={written}, file={CSV_PATH}")

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        with prog_lock:
            state["stop_flag"] = True
        log("Interrupted by user. Exiting gracefully.")
        sys.exit(130)
